# ClashKing Dashboard - Environment Variables

# ⚠️ IMPORTANT: The dashboard requires ClashKingAPI v2 branch running locally
# See README.md for setup instructions

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Discord OAuth2 Client ID
# Get this from Discord Developer Portal: https://discord.com/developers/applications
# This is PUBLIC information (visible in OAuth URLs), not a secret
NEXT_PUBLIC_DISCORD_CLIENT_ID=your_discord_client_id
